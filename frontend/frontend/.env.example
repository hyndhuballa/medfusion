# MedFusion Surveillance Hub — Environment Variables
# Copy this file to .env.local and fill in your values

# Backend API base URL (MedFest backend)
# Leave empty to use mock data
NEXT_PUBLIC_API_BASE_URL=

# Example (once your backend is running):
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# NEXT_PUBLIC_API_BASE_URL=https://your-medfest-api.com
